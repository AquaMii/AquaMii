<%- include('../partials/header') %>

<div id="body" class="activity" data-region-id="2">
    <div class="title-header text-header">
        <div class="header-banner-container">
            <div class="header-banner">
                <p>Please sign in to access the Miiverse network.</p>
            </div>
        </div>
        <h1 class="info-content">
            <span class="icon-container"></span>
            <span class="title-container">
                <span class="title"><span>Sign In</span></span>
            </span>
        </h1>
    </div>

    <div class="body-content" id="login-form-container">
        <div class="no-content-window">
            <div class="window">
                <form action="/account/login" method="POST" style="padding: 20px;">
                    <div style="margin-bottom: 10px;">
                        <input type="text" name="username" placeholder="Username" required 
                               style="width: 80%; padding: 4px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                    <div style="margin-bottom: 10px;">
                        <input type="password" name="password" placeholder="Password" required 
                               style="width: 80%; padding: 4px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>

                    <div class="window-bottom-buttons">
                        <button type="button" class="back-button button" onClick="history.back();">Back</button>
                        <button type="submit" class="button" style="background: #e65c00; color: white; border: none;">Log In</button>
                    </div>
                </form>

                <p style="text-align: center; padding-bottom: 15px;">
                    Don't have an AquaMii account? <a href="/account/register">Register</a>
                </p>
            </div>
        </div>
    </div>
</div>